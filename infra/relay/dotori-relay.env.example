# /etc/dotori-relay.env 로 복사해 실제 값으로 채운다 (root:relay, chmod 640).
# systemd EnvironmentFile이 이 값을 릴레이 프로세스에 주입한다.

PORT=8787

# CORS 허용 Origin (프로덕션 도메인). 프리뷰(*-h4ppy-bee.vercel.app)는 코드의 정규식으로 별도 허용된다.
ALLOWED_ORIGINS=https://dotori-h4ppy-bee.vercel.app

# 봇 1차 필터용 공유 시크릿. Vercel의 NEXT_PUBLIC_RELAY_SECRET과 동일한 값으로 맞춘다.
# 생성 예: openssl rand -hex 24
RELAY_SECRET=__강력한_랜덤값__

TOSS_API_BASE=https://openapi.tossinvest.com
RATE_MAX=60
BODY_LIMIT=65536
# 토스 호출 타임아웃(ms). 운영에서는 반드시 설정한다.
FETCH_TIMEOUT_MS=10000

# Caddy가 사용할 도메인 (nip.io). VM 공인 IP가 203.0.113.5 면 203.0.113.5.nip.io
RELAY_DOMAIN=__VM_PUBLIC_IP__.nip.io
